		{
			"name": "Retrieve the Review and Check for Raw Script Tags Request Copy",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"const body = pm.response.text();\r",
							"const res = pm.response.json();\r",
							"\r",
							"pm.test(\"Reviews endpoint returns 200\", () => {\r",
							"  pm.response.to.have.status(200);\r",
							"});\r",
							"\r",
							"pm.test(\"Script tags must be escaped — not raw\", () => {\r",
							"  pm.expect(body).to.not.include(\"<script>\");\r",
							"});\r",
							"\r",
							"pm.test(\"No event handler attributes in response\", () => {\r",
							"  pm.expect(body).to.not.include(\"onerror=\");\r",
							"  pm.expect(body).to.not.include(\"onload=\");\r",
							"  pm.expect(body).to.not.include(\"onclick=\");\r",
							"});\r",
							"\r",
							"pm.test(\"No javascript: URIs in response\", () => {\r",
							"  pm.expect(body).to.not.include(\"javascript:\");\r",
							"});\r",
							"\r",
							"const scriptMatch = body.match(/<script.*?>.*?<\\/script>/gi);\r",
							"\r",
							"if (scriptMatch) {\r",
							"    console.log(\"XSS Script Found:\");\r",
							"    scriptMatch.forEach((script, index) => {\r",
							"        console.log(`Script ${index + 1}:`, script);\r",
							"    });\r",
							"} else {\r",
							"    console.log(\"No script tag found in response\");\r",
							"}"
						],
						"type": "text/javascript",
						"packages": {}
					}
				}
			],
			"request": {
				"auth": {
					"type": "noauth"
				},
				"method": "GET",
				"header": [
